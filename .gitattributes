# Normalize line endings: store all text as LF in the repository.
# This keeps diffs clean across macOS/Linux/Windows contributors.
* text=auto eol=lf

# Shell scripts run on Linux servers — they MUST be LF or they break.
*.sh   text eol=lf

# Windows-only scripts (if ever added) keep CRLF.
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Binary assets — never normalize or diff as text.
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
