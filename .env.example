# ─── REQUIRED ──────────────────────────────────────────────────────────
# Bearer token for the REST API. Generate with: openssl rand -hex 32
HUB_TOKEN=replace-me-with-a-32-byte-random-hex-string

# HMAC secret for signing outbound webhooks (X-Hub-Signature header).
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=replace-me-with-another-32-byte-random-hex-string

# ─── OPTIONAL ──────────────────────────────────────────────────────────
HUB_NAME=wa-hub-demo
HUB_PORT=3060
WS_PORT=3061

# Bind addresses. Default to loopback (127.0.0.1) so the API/WS are reachable
# ONLY via a reverse proxy / tunnel on the same host. Set to 0.0.0.0 to expose
# the ports directly — and then firewall them yourself.
HUB_HOST=127.0.0.1
WS_HOST=127.0.0.1

# Optional second token for destructive/config routes (POST /instance/logout,
# PUT /instance/webhook). When set, those routes also require the X-Admin-Token
# header — so a leaked send/read token can't repoint your webhook or de-pair you.
# Leave empty to keep the simple single-token model. openssl rand -hex 32
ADMIN_TOKEN=

# Where to POST incoming WhatsApp events.
# Leave empty to disable. Can also be set at runtime via PUT /api/instance/webhook
WEBHOOK_URL=

# Comma-separated list of events to deliver. Empty = all.
# Available: message.incoming, message.outgoing, message.status,
#            instance.connected, instance.disconnected, instance.qr
WEBHOOK_EVENTS=

# Requests per minute per client IP. 0 = unlimited.
RATE_LIMIT_PER_MIN=120

# Max concurrent media (image/file/audio) sends. Bounds peak memory; excess
# requests queue and then get a 503. Raise only if you have RAM headroom.
MEDIA_CONCURRENCY=4

# Max simultaneous WebSocket clients. Extra connections are closed with 1013.
WS_MAX_CLIENTS=64

# Trust X-Forwarded-* / CF-Connecting-IP so the rate limiter sees the real
# client IP. Enable (true) ONLY behind a reverse proxy / tunnel you control —
# otherwise a direct client could spoof its IP to dodge the limiter. Behind the
# Cloudflare Tunnel install this should be true.
TRUST_PROXY=false

# Allow outbound webhook/media fetches to private/loopback/link-local addresses.
# OFF by default — blocks SSRF to internal services and cloud metadata
# (169.254.169.254). Turn on ONLY if your webhook receiver lives on a private
# network and you accept the risk.
ALLOW_PRIVATE_EGRESS=false

# Accept the API token via the ?token= query string on REST routes. OFF by
# default (URLs leak into proxy/access logs & browser history). The
# Authorization: Bearer header is always accepted.
ALLOW_QUERY_TOKEN=false

# Comma-separated Origin allowlist for browser WebSocket clients. Empty = no
# Origin restriction (the token still gates access). e.g. https://app.example.com
WS_ALLOWED_ORIGINS=

# Auth session directory (persisted across restarts).
DATA_DIR=./data

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Max tasks queued in the outbound send/pacing FIFO before new sends are shed with
# a 503 (send_queue_full). Bounds memory — each queued media send holds its decoded
# bytes — and stops a flood from growing the queue without limit when pacing is on.
SEND_QUEUE_MAX=500

# Webhook delivery bounds. Cap concurrent in-flight POSTs and the backlog behind
# them so a slow/failing receiver during an inbound burst can't pile up retained
# bodies, retry timers and sockets. Past the backlog cap, deliveries are shed.
WEBHOOK_CONCURRENCY=10
WEBHOOK_MAX_QUEUE=1000
